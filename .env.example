# ─────────────────────────────────────────────────────────────
# Aphrodite Research — environment
# Copy to `.env.local` for local dev; set the same keys in the
# Vercel project (Settings → Environment Variables) for deploy.
# NEVER commit real values. NEVER expose SERVICE_ROLE or ANTHROPIC
# keys to the browser — they are server-only.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# From Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Public "anon" key — safe to expose to the browser (RLS enforces access).
# Served to the frontend via /api/public-config.
SUPABASE_ANON_KEY=your-anon-key

# Service-role key — SERVER ONLY. Bypasses RLS. Used by /api/ask to
# read reference tables and write query_logs. Never send to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic ─────────────────────────────────────────────────
# SERVER ONLY. Used exclusively inside /api/ask (step 6).
ANTHROPIC_API_KEY=sk-ant-your-key
# Model id for the grounded generation step. See docs — default is a
# current, capable Claude model.
ANTHROPIC_MODEL=claude-sonnet-5

# ── Optional ──────────────────────────────────────────────────
# When "true", /api/ask returns a deterministic receipt assembled
# straight from the DB records without calling Anthropic. Lets you run
# the full loop (retrieval, safety gate, receipt render, logging)
# before you have an Anthropic key. Set to "false" in production.
ASK_MODEL_DISABLED=false
